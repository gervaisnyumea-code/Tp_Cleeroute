# =============================================================================
# Exemple de variables d'environnement — copier vers .env en local uniquement
# =============================================================================
# Sur Render, PORT et RENDER_EXTERNAL_URL sont fournis automatiquement.
# Ne commite JAMAIS le fichier .env (secrets / config machine).
# =============================================================================

# Port d'écoute : en local, 4000 par défaut ; sur Render, PORT est imposé par la plateforme.
# PORT=4000

# Optionnel : URL publique pour la doc Swagger (sinon détection auto via RENDER_EXTERNAL_URL).
# PUBLIC_URL=https://ton-service.onrender.com
